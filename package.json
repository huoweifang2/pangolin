{
  "name": "pangolin",
  "version": "0.1.0",
  "description": "Pangolin Agent Communication Security Gateway",
  "keywords": [],
  "homepage": "https://github.com/huoweifang2/pangolin#readme",
  "bugs": {
    "url": "https://github.com/huoweifang2/pangolin/issues"
  },
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huoweifang2/pangolin.git"
  },
  "bin": {
    "pangolin": "pangolin.mjs"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "pangolin.mjs",
    "README-header.png",
    "README.md",
    "assets/",
    "dist/",
    "docs/",
    "extensions/",
    "skills/"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./plugin-sdk": {
      "types": "./dist/plugin-sdk/index.d.ts",
      "default": "./dist/plugin-sdk/index.js"
    },
    "./plugin-sdk/account-id": {
      "types": "./dist/plugin-sdk/account-id.d.ts",
      "default": "./dist/plugin-sdk/account-id.js"
    },
    "./cli-entry": "./pangolin.mjs"
  },
  "scripts": {
    "android:assemble": "bash scripts/core-only-disabled.sh android:assemble",
    "android:install": "bash scripts/core-only-disabled.sh android:install",
    "android:run": "bash scripts/core-only-disabled.sh android:run",
    "android:test": "bash scripts/core-only-disabled.sh android:test",
    "build": "pnpm canvas:a2ui:bundle && tsdown && pnpm build:plugin-sdk:dts && node --import tsx scripts/write-plugin-sdk-entry-dts.ts && node --import tsx scripts/canvas-a2ui-copy.ts && node --import tsx scripts/copy-hook-metadata.ts && node --import tsx scripts/write-build-info.ts && node --import tsx scripts/write-cli-compat.ts",
    "build:plugin-sdk:dts": "tsc -p tsconfig.plugin-sdk.dts.json",
    "canvas:a2ui:bundle": "bash scripts/bundle-a2ui.sh",
    "check": "pnpm format:check && pnpm tsgo && pnpm lint",
    "check:docs": "pnpm format:docs:check && pnpm lint:docs && pnpm docs:check-links",
    "check:loc": "node --import tsx scripts/check-ts-max-loc.ts --max 500",
    "dev": "node scripts/run-node.mjs",
    "docs:bin": "node scripts/build-docs-list.mjs",
    "docs:check-links": "node scripts/docs-link-audit.mjs",
    "docs:dev": "cd docs && mint dev",
    "docs:list": "node scripts/docs-list.js",
    "format": "oxfmt --write",
    "format:all": "pnpm format",
    "format:check": "oxfmt --check",
    "format:docs": "git ls-files 'docs/**/*.md' 'docs/**/*.mdx' 'README.md' | xargs oxfmt --write",
    "format:docs:check": "git ls-files 'docs/**/*.md' 'docs/**/*.mdx' 'README.md' | xargs oxfmt --check",
    "format:swift": "bash scripts/core-only-disabled.sh format:swift",
    "gateway:dev": "AGENT_SHIELD_SKIP_CHANNELS=1 node scripts/run-node.mjs --dev gateway",
    "gateway:dev:reset": "AGENT_SHIELD_SKIP_CHANNELS=1 node scripts/run-node.mjs --dev gateway --reset",
    "gateway:watch": "node scripts/watch-node.mjs gateway --force",
    "ios:build": "echo 'iOS removed in pangolin edition'",
    "ios:gen": "bash scripts/core-only-disabled.sh ios:gen",
    "ios:open": "echo 'iOS removed in pangolin edition'",
    "ios:run": "echo 'iOS removed in pangolin edition'",
    "lint": "oxlint --type-aware",
    "lint:all": "pnpm lint",
    "lint:docs": "pnpm dlx markdownlint-cli2",
    "lint:docs:fix": "pnpm dlx markdownlint-cli2 --fix",
    "lint:fix": "oxlint --type-aware --fix && pnpm format",
    "lint:swift": "bash scripts/core-only-disabled.sh lint:swift",
    "mac:open": "echo 'macOS app removed in pangolin edition'",
    "mac:package": "bash scripts/package-mac-app.sh",
    "mac:restart": "bash scripts/restart-mac.sh",
    "moltbot:rpc": "node scripts/run-node.mjs agent --mode rpc --json",
    "openclaw:doctor": "bash scripts/openclaw-doctor.sh",
    "openclaw:doctor:strict": "bash scripts/openclaw-doctor.sh --strict",
    "pangolin": "node scripts/run-node.mjs",
    "pangolin:dev:all": "bash scripts/pangolin-dev-up.sh",
    "pangolin:frontend:build": "pnpm --filter ai-protector-frontend build",
    "pangolin:frontend:dev": "pnpm --filter ai-protector-frontend dev",
    "pangolin:frontend:preview": "pnpm --filter ai-protector-frontend preview",
    "pangolin:rpc": "node scripts/run-node.mjs agent --mode rpc --json",
    "phase6:audit:legacy": "node scripts/phase6-legacy-path-audit.mjs",
    "phase6:audit:legacy:strict": "node scripts/phase6-legacy-path-audit.mjs --strict",
    "plugins:sync": "node --import tsx scripts/sync-plugin-versions.ts",
    "prepack": "pnpm build",
    "prepare": "command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath git-hooks || exit 0",
    "protocol:check": "pnpm protocol:gen",
    "protocol:gen": "node --import tsx scripts/protocol-gen.ts",
    "protocol:gen:swift": "node --import tsx scripts/protocol-gen-swift.ts",
    "release:check": "node --import tsx scripts/release-check.ts",
    "start": "node scripts/run-node.mjs",
    "test": "node scripts/test-parallel.mjs",
    "test:all": "pnpm lint && pnpm build && pnpm test && pnpm test:e2e",
    "test:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:docker:all": "bash scripts/core-only-disabled.sh test:docker:all",
    "test:docker:cleanup": "bash scripts/core-only-disabled.sh test:docker:cleanup",
    "test:docker:doctor-switch": "bash scripts/core-only-disabled.sh test:docker:doctor-switch",
    "test:docker:gateway-network": "bash scripts/core-only-disabled.sh test:docker:gateway-network",
    "test:docker:live-gateway": "bash scripts/core-only-disabled.sh test:docker:live-gateway",
    "test:docker:live-models": "bash scripts/core-only-disabled.sh test:docker:live-models",
    "test:docker:onboard": "bash scripts/core-only-disabled.sh test:docker:onboard",
    "test:docker:plugins": "bash scripts/core-only-disabled.sh test:docker:plugins",
    "test:docker:qr": "bash scripts/core-only-disabled.sh test:docker:qr",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:fast": "vitest run --config vitest.unit.config.ts",
    "test:force": "node --import tsx scripts/test-force.ts",
    "test:install:e2e": "bash scripts/test-install-sh-e2e-docker.sh",
    "test:install:e2e:anthropic": "AGENT_SHIELD_E2E_MODELS=anthropic bash scripts/test-install-sh-e2e-docker.sh",
    "test:install:e2e:openai": "AGENT_SHIELD_E2E_MODELS=openai bash scripts/test-install-sh-e2e-docker.sh",
    "test:install:smoke": "bash scripts/test-install-sh-docker.sh",
    "test:live": "AGENT_SHIELD_LIVE_TEST=1 vitest run --config vitest.live.config.ts",
    "test:macmini": "AGENT_SHIELD_TEST_VM_FORKS=0 AGENT_SHIELD_TEST_PROFILE=serial node scripts/test-parallel.mjs",
    "test:ui": "bash scripts/core-only-disabled.sh test:ui",
    "test:watch": "vitest",
    "tsgo:test": "tsgo -p tsconfig.test.json",
    "tui": "node scripts/run-node.mjs tui",
    "tui:dev": "AGENT_SHIELD_PROFILE=dev node scripts/run-node.mjs --dev tui",
    "ui:build": "bash scripts/core-only-disabled.sh ui:build",
    "ui:dev": "bash scripts/core-only-disabled.sh ui:dev",
    "ui:install": "bash scripts/core-only-disabled.sh ui:install"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.14.1",
    "@aws-sdk/client-bedrock": "^3.990.0",
    "@clack/prompts": "^1.0.1",
    "@homebridge/ciao": "^1.3.5",
    "@lydell/node-pty": "1.2.0-beta.3",
    "@mariozechner/pi-agent-core": "0.52.12",
    "@mariozechner/pi-ai": "0.52.12",
    "@mariozechner/pi-coding-agent": "0.52.12",
    "@mariozechner/pi-tui": "0.52.12",
    "@mozilla/readability": "^0.6.0",
    "@sinclair/typebox": "0.34.48",
    "ajv": "^8.18.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "file-type": "^21.3.0",
    "https-proxy-agent": "^7.0.6",
    "jiti": "^2.6.1",
    "json5": "^2.2.3",
    "jszip": "^3.10.1",
    "long": "^5.3.2",
    "markdown-it": "^14.1.1",
    "osc-progress": "^0.3.0",
    "pdfjs-dist": "^5.4.624",
    "playwright-core": "1.58.2",
    "proper-lockfile": "^4.1.2",
    "sharp": "^0.34.5",
    "signal-utils": "^0.21.1",
    "sqlite-vec": "0.1.7-alpha.2",
    "tar": "7.5.9",
    "tslog": "^4.10.2",
    "undici": "^7.22.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lit-labs/signals": "^0.2.0",
    "@lit/context": "^1.1.6",
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.2.3",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260215.1",
    "@vitest/coverage-v8": "^4.0.18",
    "lit": "^3.3.2",
    "ollama": "^0.6.3",
    "oxfmt": "0.32.0",
    "oxlint": "^1.47.0",
    "oxlint-tsgolint": "^0.13.0",
    "rolldown": "1.0.0-rc.4",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@napi-rs/canvas": "^0.1.89",
    "node-llama-cpp": "3.15.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "minimumReleaseAge": 2880,
    "overrides": {
      "fast-xml-parser": "5.3.4",
      "form-data": "2.5.4",
      "qs": "6.14.2",
      "@sinclair/typebox": "0.34.48",
      "tar": "7.5.9",
      "tough-cookie": "4.1.3"
    },
    "onlyBuiltDependencies": [
      "@lydell/node-pty",
      "@matrix-org/matrix-sdk-crypto-nodejs",
      "@napi-rs/canvas",
      "authenticate-pam",
      "esbuild",
      "node-llama-cpp",
      "protobufjs",
      "sharp"
    ]
  }
}
