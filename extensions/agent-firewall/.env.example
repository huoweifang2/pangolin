# Agent Firewall Configuration
# Copy this file to .env and fill in your API keys

# L2 Semantic Analysis (LLM Backend)
AF_L2_ENABLED=1
AF_L2_MODEL_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
AF_L2_API_KEY=your-openrouter-api-key-here
AF_L2_MODEL=deepseek/deepseek-v3.2-speciale
AF_L2_TIMEOUT=10.0

# L1 Static Analysis
AF_L1_ENABLED=1

# Network Configuration
AF_LISTEN_HOST=127.0.0.1
AF_LISTEN_PORT=9090
AF_UPSTREAM_HOST=127.0.0.1
AF_UPSTREAM_PORT=3000
AF_TRANSPORT_MODE=sse

# Rate Limiting
AF_RATE_LIMIT_RPS=100
AF_RATE_LIMIT_BURST=200

# Session Management
AF_SESSION_BUFFER_SIZE=64
AF_SESSION_TTL=3600

# Audit Log
AF_AUDIT_LOG=./audit/firewall.jsonl

# Service API Keys (optional)
AF_TAVILY_API_KEY=

# Blocked Commands (comma-separated)
AF_BLOCKED_COMMANDS=rm -rf,/etc/shadow,/etc/passwd,DROP TABLE,DELETE FROM,TRUNCATE,shutdown,mkfs,dd if=,FORMAT C:,wget|sh,curl|bash

# ── Feishu/Lark Channel ──────────────────────────────────────────
AF_FEISHU_ENABLED=1
AF_FEISHU_APP_ID=cli_a925cba144f9dbb6
AF_FEISHU_APP_SECRET=cdZ71qTMPZoo9ernzyzatfRHR1PvDOXg
AF_FEISHU_ENCRYPT_KEY=
AF_FEISHU_VERIFICATION_TOKEN=

# ── Storage (Phase 1) ─────────────────────────────────────────────
# Storage backend: "jsonl" (default, lightweight) or "sqlite" (structured queries)
AF_STORAGE_BACKEND=jsonl

# Storage path:
# - For JSONL: directory containing *.jsonl files (default: ./data)
# - For SQLite: full path to database file (e.g., ./data/firewall.db)
AF_STORAGE_PATH=./data
